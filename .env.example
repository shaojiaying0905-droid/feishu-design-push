# Optional
# Keep USE_OPENAI=0 for the free rules-based digest.
USE_OPENAI=0

# Optional
# Required only when USE_OPENAI=1.
OPENAI_API_KEY=sk-your-openai-api-key

# Required
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Optional
# If you enable "signature verification" for the Feishu custom bot, paste the secret here.
FEISHU_SECRET=

# Optional
# Keep this default unless you know which model you prefer.
OPENAI_MODEL=gpt-4.1-mini

# Optional
# Set to 1 when testing locally so it prints the digest but does not send to Feishu.
DRY_RUN=0

# Optional
# Set to 1 to skip OpenAI and send a fixed test message to Feishu.
MOCK_DIGEST=0
